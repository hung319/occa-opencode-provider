      "key": "sk-YOUR-KEY-HERE",
      "type": "openai"
    },
    "claude": {
      "baseurl": "https://api.anthropic.com",
      "key": "sk-ant-YOUR-KEY-HERE",
      "type": "claude"
    },
    "gemini": {
      "baseurl": "https://generativelanguage.googleapis.com/v1beta",
      "key": "AIza-YOUR-KEY-HERE",
